DJANGO_SECRET_KEY=your-secret-key-here

# AI parser
PARSER_BACKEND=mock
YANDEX_FOLDER_ID=
YANDEX_API_KEY=

# PostgreSQL
POSTGRES_DB=suetolog_db
POSTGRES_USER=suetolog_user
POSTGRES_PASSWORD=suetolog_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=

# Host values above are used by pipenv processes.
# docker-compose.yml overrides them inside app containers with:
# POSTGRES_HOST=postgres
# REDIS_URL=redis://redis:6379/0
